{
  "name": "my-mcp-server",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "my-mcp-server": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "web": "node web/server.mjs",
    "tunnels": "ngrok start --all",
    "tunnels:list": "node -e \"fetch('http://127.0.0.1:4040/api/tunnels').then(r=>r.json()).then(d=>d.tunnels.forEach(t=>console.log(t.public_url,'->',t.config.addr)))\""
  },
  "files": [
    "build"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  }
}
